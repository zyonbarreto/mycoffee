# Copy this file to .env.local and paste your key. Vite only exposes
# variables that start with VITE_.

# One Google key runs the whole app: the map tiles and the shop lookups.
# Lock it to your website (HTTP referrer) and enable two APIs on it:
#   - Maps JavaScript API
#   - Places API (New)
VITE_MAPS_BROWSER_KEY=PASTE_YOUR_GOOGLE_KEY_HERE
